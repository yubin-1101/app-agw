<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.company.agw.domain.ranking.RankingMapper">

    <select id="selectRankingKeywords" resultType="java.lang.String">
        SELECT keyword
        FROM tb_spam_ranking
        WHERE ranking_type = #{rankingType}
        ORDER BY rank_no ASC
        LIMIT 10
    </select>
</mapper>
