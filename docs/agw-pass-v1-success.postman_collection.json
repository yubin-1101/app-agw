{
  "info": {
    "_postman_id": "9b80b00a-0f0e-4a57-a0a0-0d676c8a2b0d",
    "name": "AGW PASS v1 - Success Tests",
    "description": "Success-case collection for implemented PASS v1 APIs. The collection-level test asserts HTTP 200, JSON response, retCode=1000, and retMsg. Update collection variables to values that exist in the current DB/storage before running. getSpamFileData requires an accessible file/storage path. removeSpamMsg is destructive and deletes the configured message.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "let json;",
          "",
          "pm.test('HTTP status is 200', function () {",
          "  pm.response.to.have.status(200);",
          "});",
          "",
          "pm.test('response body is JSON object', function () {",
          "  json = pm.response.json();",
          "  pm.expect(json).to.be.an('object');",
          "});",
          "",
          "pm.test('retCode is 1000', function () {",
          "  pm.expect(json).to.have.property('retCode', 1000);",
          "});",
          "",
          "pm.test('retMsg exists', function () {",
          "  pm.expect(json).to.have.property('retMsg');",
          "  pm.expect(json.retMsg).to.be.a('string');",
          "});"
        ]
      }
    }
  ],
