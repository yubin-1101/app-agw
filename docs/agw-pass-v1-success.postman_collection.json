          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "pm.test('file data response shape is valid', function () {",
                  "  pm.expect(json).to.have.property('seqNO', '9970052025052913192450588');",
                  "  pm.expect(json.fileData).to.be.an('array');",
                  "  pm.expect(json.fileData.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.test('fileData contains filename to base64 map', function () {",
                  "  json.fileData.forEach(function (fileMap) {",
                  "    pm.expect(fileMap).to.be.an('object');",
                  "    Object.keys(fileMap).forEach(function (name) {",
                  "      pm.expect(fileMap[name]).to.be.a('string').and.not.empty;",
                  "    });",
                  "  });",
                  "});"
                ]
              }
            }
          ],
