          "name": "getSpamMsgList - success",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "pm.test('spam list response shape is valid', function () {",
                  "  pm.expect(json.spamListCnt).to.be.a('number');",
                  "  pm.expect(json.spamMsgList).to.be.an('array');",
                  "  pm.expect(json.spamMsgList.length).to.eql(json.spamListCnt);",
                  "});",
                  "",
                  "pm.test('spam rows use PASS v1 tuple format', function () {",
                  "  json.spamMsgList.forEach(function (row) {",
                  "    pm.expect(row).to.be.an('array');",
                  "    pm.expect(row.length).to.be.at.least(10);",
                  "  });",
                  "});"
                ]
              }
            }
          ],
